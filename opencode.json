{
  "$schema": "https://opencode.ai/config.json",
  "permission": "allow",
  "mcp": {
    "sentry": {
      "type": "local",
      "command": ["npx", "-y", "@sentry/mcp-server@latest"],
      "environment": {
        "SENTRY_ACCESS_TOKEN": "{env:SENTRY_AUTH_TOKEN}"
      }
    },
    "linear": {
      "type": "local",
      "command": ["npx", "-y", "github:obra/streamlinear"],
      "environment": {
        "LINEAR_API_TOKEN": "{env:LINEAR_API_TOKEN}"
      }
    }
  }
}
